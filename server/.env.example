# Porta da API
PORT=5000

# MongoDB (local ou MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/buscahoteis

# JWT
JWT_SECRET=troque-por-um-segredo-bem-forte
JWT_EXPIRES_IN=7d

# RapidAPI - Booking.com (https://rapidapi.com/DataCrawler/api/booking-com15)
# Sem essa chave, a API usa automaticamente dados mock locais.
RAPIDAPI_KEY=
RAPIDAPI_HOST=booking-com15.p.rapidapi.com

# Unsplash (https://unsplash.com/developers) - usado como fallback de imagens
UNSPLASH_ACCESS_KEY=

# URL do frontend (usado em CORS)
CLIENT_URL=http://localhost:3000
